# Kopiere diese Datei nach backend/.env und passe die Werte an.

# Datenbank
DATABASE_URL=postgresql://access_user:access_pass@localhost:5440/access_mobility

# Sicherheit
SECRET_KEY=change-me-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — Frontend-URL (Komma-getrennt für mehrere Origins)
ALLOWED_ORIGINS=http://localhost:5180

# Website-Testzugänge werden in der Datenbank verwaltet (preview_access_users-Tabelle).
# Verwaltung über /platform-admin/test-access im App-Portal (Rolle: platform_admin).
# Kein Zugangscode in Umgebungsvariablen erforderlich.
